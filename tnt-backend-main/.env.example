# =============================================================================
# TNT (Track & Transact) — Backend Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tnt

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                          # development | production | staging
SECRET_KEY=dev_only_insecure_secret_do_not_use_in_production
OTP_HMAC_KEY=dev_otp_key_change_in_production
JWT_ALGORITHM=HS256
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_FAKE_REDIS=true

# ── SMS / Messaging Providers ────────────────────────────────────────────────
SMS_ENABLED=false
SMS_PROVIDER=twilio                          # twilio | msg91
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
